<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_dark"
    android:padding="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp">

    <!-- Poster -->
    <ImageView
        android:id="@+id/ivPoster"
        android:layout_width="100dp"
        android:layout_height="150dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_poster_placeholder"
        android:layout_marginEnd="14dp"
        android:contentDescription="Poster phim" />

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="6dp" />

        <!-- Genre chip -->
        <TextView
            android:id="@+id/tvGenre"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:textSize="11sp"
            android:textColor="@color/text_on_accent"
            android:textStyle="bold"
            android:background="@drawable/bg_genre_chip_active"
            android:layout_marginBottom="6dp" />

        <!-- Duration -->
        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="10dp" />

        <!-- Action button -->
        <TextView
            android:id="@+id/btnViewShowtimes"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:gravity="center"
            android:text="Xem lịch chiếu"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_accent"
            android:background="@drawable/bg_accent_rounded" />
    </LinearLayout>
</LinearLayout>
