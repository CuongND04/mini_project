<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MovieTicketApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/text_on_accent</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <style name="Theme.MovieTicketApp" parent="Base.Theme.MovieTicketApp" />

    <!-- Yellow accent button -->
    <style name="AccentButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Outlined button -->
    <style name="OutlinedAccentButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="android:textColor">@color/accent</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Text button -->
    <style name="TextAccentButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
    </style>

    <!-- Alert Dialog -->
    <style name="AlertDialogDark" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/bg_surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/TextAccentButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/TextAccentButton</item>
    </style>

    <!-- Input field style -->
    <style name="DarkInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
</resources>
